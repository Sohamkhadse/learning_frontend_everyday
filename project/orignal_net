<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>netflix</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            font-family: sans-serif;
        }

        .hero-container {
            background: linear-gradient(0deg, rgba(0, 0, 0, .85), rgba(0, 0, 0, .75)), url("./bc-img.png");
            background-repeat: no-repeat;
            background-size: cover;
            background-position: center center;
            width: 100%;
            height: 100vh;
        }

        .content {
            margin: 0 auto;
            width: 65%;
            height: 100vh;
            padding: 0 2rem;
            display: grid;
            grid-template-columns: 1fr;
            grid-template-rows: auto 1fr;
        }

        .header {
            width: 100%;
            display: flex;
            align-items: center;
        }

        .logo {
            width: 250px;
        }

        .cta {
            flex-grow: 1;
            display: flex;
            align-items: stretch;
            justify-content: end;
            gap: 1rem;
        }

        .language-dropdown {
            background-color: rgba(0, 0, 0, .75) !important;
            color: white;
            padding: 0.45rem;
            border-radius: .25rem;
            border: .05rem solid gray;
            box-sizing: border-box;
        }

        .sign-btn {
            background: rgba(229, 9, 20, 1);
            outline: none;
            border: none;
            border-radius: .25rem;
            padding: 0.45rem 1.5rem;
            color: white;
            font-weight: bold;
        }

        .main {
            width: 50%;
            justify-self: center;
            align-items: center;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: stretch;
            justify-content: center;
            gap: 2rem;
            text-align: center;
        }

        .title {
            font-weight: 900;
            font-size: 4rem;
        }

        .email-data {
            margin-top: 0.5rem;
            display: flex;
            align-items: stretch;
            justify-content: center;
            gap: 1rem;
        }

        .email-field {
            flex-grow: 1;
            background-color: rgba(0, 0, 0, .55);
            padding: 1rem;
            outline: none;
            border: none;
            border: 1px solid white;
            border-radius: .45rem;
        }

        .final-btn {
            padding: 1rem 2rem !important;
            background: rgba(229, 9, 20, 1);
            color: white;
            border: none;
            outline: none;
            border-radius: 0.45rem;
            font-size: 1.5rem;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <div class="hero-container">
        <div class="content">
            <div class="header">
                <div class="logo-container">
                    <img class="logo" src="./bc-img.png" alt="netflix logo">
                </div>
                <div class="cta">
                    <select class="language-dropdown" name="" id="">
                        <option value="">English</option>
                        <option value="">Hindi</option>
                        <option value="">Marathi</option>
                    </select>
                    <button class="sign-btn">Sign In</button>
                </div>
            </div>
            <div class="main">
                <h1 class="title">Unlimited movies, shows, and more</h1>
                <span>Starts at <b>₹149</b>. Cancel at any time.</span>
                <div class="email-container">
                    <span class="text">Ready to watch? Enter your email to create or restart your membership.</span>
                    <div class="email-data">
                        <input class="email-field" type="email" placeholder="Enter Your Email">
                        <button class="final-btn">Get Started</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>